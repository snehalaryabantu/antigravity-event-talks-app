# pyenv
#   For a library or app, you might want to share your .python-version.
#   External environments: https://github.com/pyenv/pyenv#environment-variables
#  .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a binary dependency, it may cause issues.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is database file and should be included in version control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is database file and should be included in version control.
#pdm.lock

# PEP 582; projects using layout 2D requirements may have '__pypackages__' directory
